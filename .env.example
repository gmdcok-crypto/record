SONIOX_API_KEY=your_soniox_api_key_here
SONIOX_MODEL=stt-async-v4
SONIOX_ENABLE_SPEAKER_DIARIZATION=true
LANGUAGE_HINTS=ko

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=record
R2_VOICE_PREFIX=voice/
R2_TEXT_PREFIX=text/

# Railway MySQL (Variables → Reference from MySQL service)
DATABASE_URL=mysql://user:password@host:port/railway
# or MYSQL_URL=...

# One-time DB reset API token (POST /api/jobs/admin/maintenance/reset-database)
# MAINTENANCE_RESET_TOKEN=your-secret-token
# One-time startup data wipe (jobs/transcribers). Remove after redeploy.
# PURGE_DB_ON_STARTUP=1

# Transcriber PWA JWT auth (signup/login)
JWT_SECRET=change-me-to-a-long-random-string
# 0 = never expire. Example for 7 days: 10080
JWT_EXPIRE_MINUTES=0

# Intro-only Channel Talk plugin key
VITE_CHANNEL_TALK_PLUGIN_KEY=your_channel_talk_plugin_key

# Public app URLs for deep links in inquiry notifications
PUBLIC_CLIENT_URL=https://bulpen-user.netlify.app
PUBLIC_API_URL=https://record-production.up.railway.app

# PortOne 결제 시 payment_records DB 저장 (매출 관리). 격리 테스트 중에는 false 유지.
# PAYMENT_RECORDS_ENABLED=true
PUBLIC_ADMIN_URL=https://record-voi.netlify.app/admin
PUBLIC_TRANSCRIBER_URL=https://record.your-domain.com/transcriber

# Client web push notifications
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:ops@example.com
